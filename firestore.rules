rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function belongsToInstitution(instId) {
      return userExists() && getUserDoc().institution_id == instId;
    }

    function isAdminOf(instId) {
      return belongsToInstitution(instId) && getUserDoc().role == "admin";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getInstitutionDoc(instId) {
      return get(/databases/$(database)/documents/institutions/$(instId)).data;
    }

    function institutionExists(instId) {
      return exists(/databases/$(database)/documents/institutions/$(instId));
    }

    // ============================================================
    // USERS COLLECTION
    // ============================================================
    // Document ID = Firebase Auth UID.
    // Members can read other users in their institution (for "created by" display).
    // Admins can update other users' roles within their institution.
    // Admins can delete users from their institution (with last-admin protection).
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        (userExists()
          && getUserDoc().institution_id == resource.data.institution_id)
      );

      // Users can create their own doc during onboarding.
      // Founder (institution creator) may set role to "admin".
      // Everyone else must join as "member".
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && institutionExists(request.resource.data.institution_id)
        && (
          // Founder: institution's created_by matches this user → admin allowed
          (request.resource.data.role == "admin"
            && getInstitutionDoc(request.resource.data.institution_id).created_by == request.auth.uid)
          ||
          // Joiner: must be member
          request.resource.data.role == "member"
        );

      // Self-update: can change anything EXCEPT role and institution_id
      // Admin update: can change fields for users in their institution
      allow update: if isSignedIn() && (
        (request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.institution_id == resource.data.institution_id)
        ||
        (userExists()
          && getUserDoc().role == "admin"
          && getUserDoc().institution_id == resource.data.institution_id
          && request.resource.data.institution_id == resource.data.institution_id)
      );

      // Users can delete their own doc (leave institution)
      // Admins can delete users from their institution
      // Cannot delete if you are the only admin (last-admin protection)
      allow delete: if isSignedIn() && (
        // Admin removing another user from their institution
        (request.auth.uid != userId
          && userExists()
          && getUserDoc().role == "admin"
          && getUserDoc().institution_id == resource.data.institution_id)
        ||
        // Self-delete: allowed only if you're not an admin, or you are but there's no
        // last-admin risk (rules can't count admins, so block admin self-delete entirely;
        // the app handles reassignment before allowing an admin to leave)
        (request.auth.uid == userId
          && resource.data.role != "admin")
      );
    }

    // ============================================================
    // INSTITUTIONS COLLECTION
    // ============================================================
    match /institutions/{instId} {
      allow read: if isSignedIn() && belongsToInstitution(instId);
      // Creator must set created_by to themselves
      allow create: if isSignedIn()
        && request.resource.data.created_by == request.auth.uid;
      allow update: if isSignedIn() && isAdminOf(instId);
      allow delete: if isSignedIn() && isAdminOf(instId);
    }

    // ============================================================
    // INVITE CODES COLLECTION
    // ============================================================
    // Document ID = the invite code (guarantees uniqueness).
    match /invite_codes/{code} {
      allow read: if isSignedIn();
      // Allow create during institution setup (founder, no user doc yet)
      // or during regeneration (existing admin)
      allow create: if isSignedIn()
        && institutionExists(request.resource.data.institution_id)
        && (
          // Founder: institution's created_by matches this user
          getInstitutionDoc(request.resource.data.institution_id).created_by == request.auth.uid
          ||
          // Existing admin regenerating
          isAdminOf(request.resource.data.institution_id)
        );
      allow delete: if isSignedIn()
        && userExists()
        && getUserDoc().role == "admin"
        && getUserDoc().institution_id == resource.data.institution_id;
      allow update: if false;
    }

    // ============================================================
    // PROJECTS COLLECTION
    // ============================================================
    match /projects/{projectId} {
      allow read: if isSignedIn()
        && userExists()
        && getUserDoc().institution_id == resource.data.institution_id;

      allow create: if isSignedIn()
        && userExists()
        && getUserDoc().institution_id == request.resource.data.institution_id;

      // Members can update, but cannot change institution_id
      allow update: if isSignedIn()
        && userExists()
        && getUserDoc().institution_id == resource.data.institution_id
        && request.resource.data.institution_id == resource.data.institution_id;

      // Only admins can delete projects
      allow delete: if isSignedIn()
        && userExists()
        && getUserDoc().role == "admin"
        && getUserDoc().institution_id == resource.data.institution_id;
    }

    // ============================================================
    // CATCH-ALL: deny everything else
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
