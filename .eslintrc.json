{
  "env": {
    "browser": true,
    "es2020": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "globals": {
    "firebase": "readonly",
    "auth": "writable",
    "db": "writable",
    "googleProvider": "writable",
    "App": "writable",
    "Auth": "writable",
    "DB": "writable",
    "Config": "writable",
    "Tree": "writable",
    "Form": "writable",
    "Export": "writable",
    "Validation": "writable",
    "ASpaceTest": "writable",
    "FIELD_REGISTRY": "writable",
    "FIELD_CATEGORIES": "writable",
    "HIDDEN_FORM_FIELDS": "writable",
    "getFieldById": "writable",
    "getFieldByAspaceCode": "writable",
    "getFieldsByCategory": "writable",
    "getDefaultEnabledFields": "writable",
    "getDefaultableFields": "writable"
  },
  "rules": {
    "no-undef": "error",
    "no-unused-vars": ["warn", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^(auth|db|googleProvider|FIELD_CATEGORIES|HIDDEN_FORM_FIELDS|getFieldById|getFieldByAspaceCode|getFieldsByCategory|getDefaultEnabledFields|getDefaultableFields|_)"
    }],
    "no-redeclare": ["error", { "builtinGlobals": false }],
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-unreachable": "error",
    "no-constant-condition": "warn",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-var": "warn",
    "prefer-const": ["warn", { "destructuring": "all" }],
    "no-debugger": "warn",
    "no-alert": "warn",
    "no-console": "off",
    "semi": ["warn", "always"],
    "no-extra-semi": "warn"
  },
  "ignorePatterns": ["node_modules/", "lib/", "docs/"]
}
